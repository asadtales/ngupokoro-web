<style>
.contact-section {
  padding: 120px 0 80px;
  position: relative;
  z-index: 1;
}

.contact-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 80px;
  align-items: start;
}

.contact-left { display: flex; flex-direction: column; gap: 24px; }

.contact-heading {
  font-family: 'Playfair Display', serif;
  font-size: clamp(32px, 4vw, 52px);
  font-weight: 700;
  color: var(--white);
  line-height: 1.15;
  margin-top: 12px;
}

.contact-heading em { color: var(--gold); }

.contact-sub {
  font-size: 15px;
  line-height: 1.8;
  color: var(--muted);
}

.contact-details {
  display: flex;
  flex-direction: column;
  gap: 16px;
  padding: 28px 0;
  border-top: 1px solid rgba(200,168,75,0.15);
  border-bottom: 1px solid rgba(200,168,75,0.15);
}

.contact-item {
  display: flex;
  gap: 20px;
  align-items: baseline;
}

.ci-label {
  font-family: 'Space Mono', monospace;
  font-size: 9px;
  letter-spacing: 2px;
  text-transform: uppercase;
  color: rgba(200,168,75,0.5);
  min-width: 60px;
}

.ci-value {
  font-size: 14px;
  color: var(--cream);
  transition: color 0.2s;
}

a.ci-value:hover { color: var(--gold); }

.app-links {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
}

.app-chip {
  display: flex;
  align-items: center;
  gap: 8px;
  font-family: 'Space Mono', monospace;
  font-size: 10px;
  letter-spacing: 1px;
  color: var(--muted);
  border: 1px solid rgba(255,255,255,0.08);
  padding: 7px 14px;
  transition: color 0.2s, border-color 0.2s;
}

.app-chip:hover {
  color: var(--gold);
  border-color: rgba(200,168,75,0.3);
}

.chip-dot {
  width: 6px; height: 6px;
  border-radius: 50%;
  background: var(--gold);
  opacity: 0.6;
  display: block;
}

/* Card */
.contact-card {
  position: sticky;
  top: 100px;
}

.card-inner {
  background: var(--ink);
  border: 1px solid rgba(200,168,75,0.15);
  padding: 52px 44px;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: 20px;
  position: relative;
}

.card-inner::before {
  content: '';
  position: absolute;
  top: 10px; left: 10px; right: 10px; bottom: 10px;
  border: 1px solid rgba(200,168,75,0.05);
  pointer-events: none;
}

.card-title {
  font-family: 'Playfair Display', serif;
  font-size: 28px;
  font-weight: 700;
  color: var(--white);
}

.card-body {
  font-size: 14px;
  line-height: 1.75;
  color: var(--muted);
}

.cta-btn {
  display: block;
  width: 100%;
  font-family: 'Space Mono', monospace;
  font-size: 11px;
  letter-spacing: 2px;
  text-transform: uppercase;
  text-align: center;
  background: var(--gold);
  color: var(--deep);
  padding: 16px;
  font-weight: 700;
  transition: background 0.2s;
}

.cta-btn:hover { background: var(--gold-light); }

.or-divider {
  width: 100%;
  display: flex;
  align-items: center;
  gap: 12px;
}

.or-divider::before,
.or-divider::after {
  content: '';
  flex: 1;
  height: 1px;
  background: rgba(255,255,255,0.08);
}

.or-divider span {
  font-family: 'Space Mono', monospace;
  font-size: 9px;
  letter-spacing: 2px;
  text-transform: uppercase;
  color: var(--muted);
  white-space: nowrap;
}

.wa-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10px;
  width: 100%;
  font-family: 'DM Sans', sans-serif;
  font-size: 14px;
  font-weight: 500;
  color: var(--cream);
  border: 1px solid rgba(255,255,255,0.12);
  padding: 14px;
  transition: color 0.2s, border-color 0.2s, background 0.2s;
}

.wa-btn:hover {
  background: rgba(37,211,102,0.08);
  color: #25d366;
  border-color: rgba(37,211,102,0.3);
}

@media (max-width: 900px) {
  .contact-grid { grid-template-columns: 1fr; gap: 60px; }
  .contact-card { position: static; }
}

@media (max-width: 640px) {
  .contact-section { padding: 80px 0 60px; }
  .card-inner { padding: 36px 28px; }
}
</style>
