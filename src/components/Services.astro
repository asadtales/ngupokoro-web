---

<section class="services-section" id="layanan">
  <div class="container">
    <div class="section-header">
      <p class="label">01 — Layanan</p>
      <h2 class="section-heading">Apa yang kami<br><em>bangun untuk Anda</em></h2>
    </div>

    <div class="services-grid">
      {services.map((s) => (
        <div class="service-card">
          <div class="card-top">
            <span class="card-num">{s.num}</span>
            <div class="card-icon" set:html={s.icon} />
          </div>
          <h3 class="card-title">{s.title}</h3>
          <p class="card-desc">{s.desc}</p>
          <div class="card-tags">
            {s.tags.map(tag => <span class="tag">{tag}</span>)}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
.services-section {
  padding: 120px 0;
  position: relative;
  z-index: 1;
}

.section-header {
  margin-bottom: 64px;
}

.section-heading {
  font-family: 'Playfair Display', serif;
  font-size: clamp(32px, 4vw, 52px);
  font-weight: 700;
  color: var(--white);
  line-height: 1.15;
  margin-top: 14px;
}

.section-heading em {
  color: var(--gold);
}

.services-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1px;
  background: rgba(200,168,75,0.08);
  border: 1px solid rgba(200,168,75,0.08);
}

.service-card {
  background: var(--deep);
  padding: 40px 36px;
  transition: background 0.3s;
  display: flex;
  flex-direction: column;
  gap: 14px;
}

.service-card:hover {
  background: var(--ink);
}

.card-top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 4px;
}

.card-num {
  font-family: 'Space Mono', monospace;
  font-size: 10px;
  letter-spacing: 2px;
  color: rgba(200,168,75,0.4);
}

.card-title {
  font-family: 'Playfair Display', serif;
  font-size: 19px;
  font-weight: 700;
  color: var(--white);
  line-height: 1.3;
}

.card-desc {
  font-size: 14px;
  line-height: 1.75;
  color: var(--muted);
  flex: 1;
}

.card-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 6px;
  margin-top: 4px;
}

.tag {
  font-family: 'Space Mono', monospace;
  font-size: 9px;
  letter-spacing: 1.5px;
  text-transform: uppercase;
  color: var(--gold);
  border: 1px solid rgba(200,168,75,0.25);
  padding: 3px 8px;
}

@media (max-width: 1024px) {
  .services-grid { grid-template-columns: repeat(2, 1fr); }
}

@media (max-width: 640px) {
  .services-section { padding: 80px 0; }
  .services-grid { grid-template-columns: 1fr; }
  .service-card { padding: 28px 24px; }
}
</style>
